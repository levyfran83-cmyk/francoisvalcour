---
// Layout de base pour toutes les pages du site
// Props :
//   - title       : titre de l'onglet
//   - description : meta description SEO
//   - current     : route courante, pour griser l'item actif dans la nav
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Analytics from "@vercel/analytics/astro";

const {
  title = "François Valcour — Le Prix du Nom",
  description = "Site officiel de François Valcour, auteur du Prix du Nom, saga romanesque française de 1793 à 1870.",
  current = "",
  noindex = false,
  image = "/assets/cover_tome1.jpg",
  ogType = "website",
  jsonld = null,
} = Astro.props;

// URLs absolues, requises par les robots et les plateformes de partage social.
// Astro.site est défini dans astro.config (domaine de production).
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <link rel="canonical" href={canonical} />

  <!-- OpenGraph / partage social -->
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="François Valcour" />
  <meta property="og:locale" content="fr_FR" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Donnees structurees (schema.org) -->
  {jsonld && <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />}

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- RSS du Carnet (auto-détecté par les agrégateurs Feedly, Reeder, etc.) -->
  <link
    rel="alternate"
    type="application/rss+xml"
    title="Le Carnet · François Valcour"
    href="/rss.xml"
  />

  <!-- Polices : EB Garamond + Cormorant Garamond -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap"
    rel="stylesheet"
  />

  <!-- Mesure d'audience Vercel (sans cookie, anonymisée) -->
  <Analytics />
</head>
<body>
  <Nav current={current} />
  <slot />
  <Footer />
</body>
</html>
