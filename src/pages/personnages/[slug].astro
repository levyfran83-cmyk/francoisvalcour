---
// Page dynamique d'une fiche personnage
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const fiches = await getCollection("personnages", ({ data }) => !data.draft);
  return fiches.map((fiche) => ({
    params: { slug: fiche.id.replace(/\.md$/, "") },
    props: { fiche },
  }));
}

const { fiche } = Astro.props;
const { Content } = await render(fiche);

// Autres personnages pour "voir aussi"
const tous = await getCollection("personnages", ({ data }) => !data.draft);
const autres = tous
  .filter((p) => p.id !== fiche.id)
  .sort((a, b) => a.data.ordre - b.data.ordre);
---

<BaseLayout
  title={`${fiche.data.titre} — Personnage du Prix du Nom`}
  description={fiche.data.accroche}
  current="/personnages"
>
  <article class="fiche">
    <!-- ===== EN-TÊTE ===== -->
    <header class="fiche-hero">
      <div class="fiche-hero-inner">
        <div class="fiche-portrait-col">
          <div
            class="fiche-portrait"
            style={`background-image: url('${fiche.data.portrait}'); background-position: ${fiche.data.portraitPos};`}
          ></div>
        </div>
        <div class="fiche-meta-col">
          <a href="/personnages" class="retour">← Tous les personnages</a>
          <div class="fiche-statut">{fiche.data.statut}</div>
          <h1>{fiche.data.titre}</h1>
          <div class="fiche-naissance">
            Né{fiche.data.titre.startsWith("Sarah") ? "e" : ""} en {fiche.data.naissance} · {fiche.data.lieuNaissance}
          </div>
          <blockquote class="fiche-accroche">« {fiche.data.accroche} »</blockquote>
          <div class="fiche-periode">{fiche.data.periode}</div>
        </div>
      </div>
    </header>

    <!-- ===== CORPS DE LA FICHE ===== -->
    <div class="fiche-body">
      <Content />
    </div>

    <!-- ===== AUTRES PERSONNAGES ===== -->
    {autres.length > 0 && (
      <aside class="autres">
        <h2>Autres figures du roman</h2>
        <div class="autres-grid">
          {autres.map((a) => (
            <a href={`/personnages/${a.id.replace(/\.md$/, "")}`} class="autre-card">
              <div
                class="autre-portrait"
                style={`background-image: url('${a.data.portrait}'); background-position: ${a.data.portraitPos};`}
              ></div>
              <div class="autre-body">
                <h3>{a.data.titre}</h3>
                <div class="autre-statut">{a.data.statut}</div>
              </div>
            </a>
          ))}
        </div>
      </aside>
    )}
  </article>
</BaseLayout>

<style>
  .fiche-hero {
    background: linear-gradient(180deg, var(--ivoire) 0%, var(--ivoire-fonce) 100%);
    padding: 5rem 2rem;
  }
  .fiche-hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 4rem;
    align-items: center;
  }
  .fiche-portrait {
    width: 100%;
    aspect-ratio: 3/4;
    background-size: cover;
    box-shadow: 0 25px 50px -15px rgba(28, 28, 26, 0.5);
    filter: sepia(0.1);
  }
  .retour {
    display: inline-block;
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    color: var(--or);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
  }
  .fiche-statut {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    color: var(--sang);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
  }
  .fiche-meta-col h1 {
    font-size: 4rem;
    line-height: 1.05;
    color: var(--encre);
    font-weight: 500;
    margin-bottom: 0.5rem;
  }
  .fiche-naissance {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    color: var(--encre-doux);
    font-size: 1.15rem;
    margin-bottom: 2rem;
  }
  .fiche-accroche {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.35rem;
    color: var(--encre-doux);
    line-height: 1.5;
    padding: 1rem 1.5rem;
    border-left: 3px solid var(--or);
    background: rgba(168, 139, 92, 0.08);
    margin-bottom: 1.5rem;
  }
  .fiche-periode {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    color: var(--or);
    font-size: 0.95rem;
    letter-spacing: 0.1em;
  }

  /* ===== CORPS DE LA FICHE ===== */
  .fiche-body {
    max-width: 720px;
    margin: 0 auto;
    padding: 5rem 2rem 4rem;
    font-size: 1.15rem;
    line-height: 1.85;
    color: var(--encre);
  }
  .fiche-body :global(p) {
    margin-bottom: 1.4rem;
    color: var(--encre-doux);
  }
  .fiche-body :global(h2) {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    font-weight: 500;
    color: var(--encre);
    margin: 3.5rem 0 1.2rem;
    padding-left: 1.4rem;
    position: relative;
    line-height: 1.2;
  }
  .fiche-body :global(h2::before) {
    content: "✦";
    position: absolute;
    left: 0;
    color: var(--or);
    font-size: 1.1rem;
    top: 0.6rem;
  }
  .fiche-body :global(h3) {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.45rem;
    font-weight: 500;
    color: var(--sang);
    margin: 2rem 0 0.8rem;
  }
  .fiche-body :global(strong) { color: var(--encre); font-weight: 600; }
  .fiche-body :global(em) { color: var(--encre); font-style: italic; }
  .fiche-body :global(a) {
    color: var(--sang);
    border-bottom: 1px solid var(--sang);
    padding-bottom: 1px;
  }
  .fiche-body :global(blockquote) {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.3rem;
    color: var(--sang);
    line-height: 1.6;
    margin: 2rem 0;
    padding: 1.5rem 2rem;
    border-left: 3px solid var(--or);
    background: var(--ivoire-fonce);
  }
  .fiche-body :global(blockquote p) { color: var(--sang); margin-bottom: 0; }
  .fiche-body :global(hr) {
    border: none;
    height: 1px;
    background: var(--filet);
    margin: 3rem 0;
  }

  /* ===== AUTRES PERSONNAGES ===== */
  .autres {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 2rem 5rem;
  }
  .autres h2 {
    text-align: center;
    font-size: 1.7rem;
    margin-bottom: 2rem;
    color: var(--encre);
    font-weight: 500;
  }
  .autres-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }
  .autre-card {
    display: grid;
    grid-template-columns: 120px 1fr;
    background: var(--ivoire-fonce);
    text-decoration: none;
    color: inherit;
    transition: all 0.3s;
    border: 1px solid var(--filet);
  }
  .autre-card:hover {
    border-color: var(--or);
    transform: translateY(-3px);
    opacity: 1;
  }
  .autre-portrait {
    width: 120px;
    height: 160px;
    background-size: cover;
    filter: sepia(0.1);
  }
  .autre-body {
    padding: 1.2rem 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .autre-card h3 {
    font-size: 1.3rem;
    color: var(--encre);
    margin-bottom: 0.4rem;
    line-height: 1.2;
    font-weight: 500;
  }
  .autre-statut {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    color: var(--or);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  @media (max-width: 860px) {
    .fiche-hero-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      text-align: center;
    }
    .fiche-portrait { max-width: 280px; margin: 0 auto; }
    .fiche-meta-col h1 { font-size: 2.5rem; }
    .fiche-accroche { text-align: left; }
    .autre-card { grid-template-columns: 100px 1fr; }
    .autre-portrait { width: 100px; height: 140px; }
  }
</style>
