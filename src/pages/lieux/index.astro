---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import { getCollection } from "astro:content";

const tous = await getCollection("lieux", ({ data }) => !data.draft);
const lieux = tous.sort((a, b) => a.data.ordre - b.data.ordre);
---

<BaseLayout
  title="Les lieux — Le Prix du Nom"
  description="Les lieux du Prix du Nom, saga romanesque de François Valcour. Décors et demeures qui traversent le roman, en versions lecteur sans spoilers."
  current="/lieux"
>
  <PageHeader
    surtitre="Les décors du roman"
    titre="Lieux"
    accroche="Les maisons, les domaines et les villes où se joue Le Prix du Nom. Comme les fiches personnages, ces pages s'en tiennent à ce que chaque tome publié dévoile."
  />

  <section class="lieux-grid">
    {lieux.map((l) => (
      <a href={`/lieux/${l.id.replace(/\.md$/, "")}`} class="lieu-card">
        <div
          class="lieu-image"
          style={`background-image: url('${l.data.image}'); background-position: ${l.data.imagePos};`}
        ></div>
        <div class="lieu-body">
          <div class="lieu-statut">{l.data.statut}</div>
          <h2>{l.data.titre}</h2>
          <div class="lieu-localisation">{l.data.localisation}</div>
          <p class="lieu-accroche">« {l.data.accroche} »</p>
          <span class="lieu-link">Découvrir le lieu →</span>
        </div>
      </a>
    ))}
  </section>

  <section class="info-spoilers">
    <div class="info-inner">
      <h2>Pourquoi ces fiches sont volontairement incomplètes</h2>
      <p>
        Une saga de douze tomes habite ses lieux sur plusieurs décennies. Une demeure change de
        sens à mesure que les générations s'y succèdent : ce qui est un refuge dans un tome devient
        une forteresse, un tombeau ou un souvenir dans le suivant.
      </p>
      <p>
        Chaque fiche présente le lieu tel qu'il apparaît dans le tome déjà publié. À chaque nouvelle
        parution, ces pages s'enrichissent d'une couche supplémentaire — ce que la maison a vu
        passer, ce qu'elle a gardé, ce qu'elle a perdu.
      </p>
      <p>
        Pour suivre ces enrichissements en avant-première,
        <a href="/newsletter">inscrivez-vous à la Lettre de l'écritoire</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .lieux-grid {
    padding: 4rem 2rem;
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  .lieu-card {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    background: var(--ivoire);
    border: 1px solid var(--filet);
    text-decoration: none;
    color: inherit;
    transition: all 0.3s;
    overflow: hidden;
  }
  .lieu-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -15px rgba(0,0,0,0.18);
    border-color: var(--or);
    opacity: 1;
  }
  .lieu-image {
    min-height: 300px;
    background-size: cover;
    filter: sepia(0.12) saturate(0.95);
  }
  .lieu-body {
    padding: 2.5rem 2.6rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .lieu-statut {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    color: var(--or);
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 0.6rem;
  }
  .lieu-card h2 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    color: var(--encre);
    font-weight: 500;
    line-height: 1.1;
  }
  .lieu-localisation {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    color: var(--encre-doux);
    font-size: 1rem;
    margin-bottom: 1.5rem;
  }
  .lieu-accroche {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.15rem;
    color: var(--sang);
    line-height: 1.5;
    margin-bottom: 1.5rem;
    padding-left: 1.2rem;
    border-left: 2px solid var(--or);
  }
  .lieu-link {
    font-style: italic;
    color: var(--sang);
    font-size: 0.98rem;
  }

  .info-spoilers {
    background: var(--encre);
    color: var(--ivoire);
    padding: 5rem 2rem;
  }
  .info-inner {
    max-width: 720px;
    margin: 0 auto;
  }
  .info-spoilers h2 {
    color: var(--ivoire);
    font-size: 1.9rem;
    margin-bottom: 1.5rem;
    text-align: center;
    font-weight: 500;
  }
  .info-spoilers p {
    color: rgba(245, 241, 232, 0.8);
    font-size: 1.08rem;
    line-height: 1.75;
    margin-bottom: 1.2rem;
  }
  .info-spoilers a { color: var(--or-pale); border-bottom: 1px solid var(--or-pale); }
  .info-spoilers a:hover { color: var(--ivoire); }

  @media (max-width: 860px) {
    .lieu-card { grid-template-columns: 1fr; }
    .lieu-image { min-height: 220px; }
    .lieu-card h2 { font-size: 1.6rem; }
  }
</style>
