---
// Section héros de la page d'accueil
// Props : tous optionnels — défauts cohérents avec le Tome I paru et disponible
const {
  surtitre = "Une saga romanesque · 1793–1870",
  titre1 = "Le Prix",
  titre2 = "du Nom",
  accroche = `« Jusqu'où peut-on s'élever sans payer<br>le prix de ce qu'on porte ? »`,
  badge = "Disponible",
  cover = "/assets/cover_tome1.jpg",
  coverAlt = "Couverture du Tome I — La Ruelle",
  ctaPrimaire = { href: "#tome1", label: "Découvrir le Tome I" },
  ctaSecondaire = { href: "/newsletter", label: "S'inscrire à la lettre" },
} = Astro.props;
---

<header class="hero">
  <div class="hero-inner">
    <div class="hero-text">
      <div class="surtitre">{surtitre}</div>
      <h1>{titre1} <em>{titre2}</em></h1>
      <p class="accroche" set:html={accroche}></p>
      <div class="hero-cta">
        <a href={ctaPrimaire.href} class="btn">{ctaPrimaire.label}</a>
        <a href={ctaSecondaire.href} class="btn secondary">{ctaSecondaire.label}</a>
      </div>
    </div>
    <div class="hero-cover">
      {badge && <div class="badge-parution">{badge}</div>}
      <img
        src={cover}
        alt={coverAlt}
        width="900"
        height="1141"
        fetchpriority="high"
        loading="eager"
        decoding="async"
      />
    </div>
  </div>
</header>

<style>
  .hero {
    padding: 6rem 2rem 5rem;
    background: linear-gradient(180deg, var(--ivoire) 0%, var(--ivoire-fonce) 100%);
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 30%, rgba(168, 139, 92, 0.08) 0%, transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(122, 46, 31, 0.05) 0%, transparent 50%);
    pointer-events: none;
  }
  .hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
  }
  .hero-text .surtitre {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    color: var(--or);
    font-size: 1.05rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }
  .hero-text h1 {
    font-size: 4rem;
    line-height: 1.05;
    margin-bottom: 1rem;
    font-weight: 500;
  }
  .hero-text h1 em {
    color: var(--sang);
    font-style: italic;
    font-weight: 400;
  }
  .hero-text .accroche {
    font-size: 1.25rem;
    color: var(--encre-doux);
    line-height: 1.5;
    margin-bottom: 2.5rem;
    max-width: 480px;
    font-style: italic;
  }
  .hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; }

  .hero-cover {
    position: relative;
    display: flex;
    justify-content: center;
  }
  .hero-cover img {
    max-width: 380px;
    width: 100%;
    height: auto;
    border: 1px solid var(--or);
    box-shadow:
      0 30px 60px -20px rgba(28, 28, 26, 0.5),
      0 18px 36px -18px rgba(122, 46, 31, 0.3);
    transform: rotate(-2deg);
    transition: transform 0.4s ease;
  }
  .hero-cover img:hover { transform: rotate(0deg) scale(1.02); }
  .badge-parution {
    position: absolute;
    top: -10px;
    right: 30px;
    background: var(--sang);
    color: var(--ivoire);
    padding: 0.6rem 1.2rem;
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transform: rotate(8deg);
    box-shadow: 0 6px 14px -4px rgba(0,0,0,0.3);
    z-index: 2;
  }

  @media (max-width: 860px) {
    .hero-inner { grid-template-columns: 1fr; gap: 3rem; }
    .hero-text h1 { font-size: 3rem; }
    .hero-cover img { max-width: 280px; }
  }
</style>
