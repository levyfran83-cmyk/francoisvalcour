---
// En-tête commun aux pages intérieures du site
// Props :
//   - surtitre  : kicker au-dessus du titre (ex. "L'œuvre")
//   - titre     : titre H1 de la page
//   - accroche  : phrase d'introduction (optionnelle)
const { surtitre = "", titre, accroche = "" } = Astro.props;
---

<header class="page-header">
  <div class="page-header-inner">
    {surtitre && <div class="page-surtitre">{surtitre}</div>}
    <h1>{titre}</h1>
    <span class="filet"></span>
    {accroche && <p class="page-accroche">{accroche}</p>}
  </div>
</header>

<style>
  .page-header {
    padding: 5rem 2rem 3rem;
    background: linear-gradient(180deg, var(--ivoire) 0%, var(--ivoire-fonce) 100%);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .page-header::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 30%, rgba(168, 139, 92, 0.08) 0%, transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(122, 46, 31, 0.04) 0%, transparent 50%);
    pointer-events: none;
  }
  .page-header-inner {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
  }
  .page-surtitre {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    color: var(--or);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-size: 0.95rem;
    margin-bottom: 0.8rem;
  }
  .page-header h1 {
    font-size: 3.5rem;
    line-height: 1.1;
    font-weight: 500;
    margin-bottom: 0.5rem;
  }
  .filet {
    display: block;
    width: 80px;
    height: 1px;
    background: var(--or);
    margin: 1.2rem auto 1.5rem;
  }
  .page-accroche {
    font-size: 1.2rem;
    color: var(--encre-doux);
    line-height: 1.6;
    font-style: italic;
    max-width: 600px;
    margin: 0 auto;
  }

  @media (max-width: 860px) {
    .page-header h1 { font-size: 2.5rem; }
    .page-accroche { font-size: 1.05rem; }
  }
</style>
