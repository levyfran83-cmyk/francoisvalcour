---
// Carte d'aperçu d'un article du Carnet
// Props :
//   - href     : lien vers l'article
//   - image    : URL de la vignette
//   - imagePos : valeur CSS pour background-position (par défaut "center")
//   - rubrique : "Personnage" | "Histoire & fiction" | "Le chantier" | ...
//   - date     : "12 mai 2026"
//   - titre    : titre de l'article
//   - extrait  : aperçu (2-3 lignes)
const {
  href,
  image,
  imagePos = "center",
  rubrique,
  date,
  titre,
  extrait,
} = Astro.props;
---

<a href={href} class="article-card">
  <div class="article-img" style={`background-image: url('${image}'); background-position: ${imagePos};`}></div>
  <div class="article-body">
    <div class="article-meta">{rubrique} · {date}</div>
    <h3>{titre}</h3>
    <p>{extrait}</p>
    <span class="lire-suite">Lire la suite →</span>
  </div>
</a>

<style>
  .article-card {
    display: block;
    background: var(--ivoire);
    border: 1px solid var(--filet);
    transition: all 0.3s;
    text-decoration: none;
    color: inherit;
  }
  .article-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -15px rgba(0,0,0,0.15);
    opacity: 1;
  }
  .article-img {
    width: 100%;
    height: 220px;
    background-size: cover;
    filter: sepia(0.15) saturate(0.9);
  }
  .article-body { padding: 1.5rem 1.8rem 2rem; }
  .article-meta {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    color: var(--or);
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.6rem;
  }
  .article-card h3 {
    font-size: 1.4rem;
    line-height: 1.3;
    margin-bottom: 0.8rem;
  }
  .article-card p {
    color: var(--encre-doux);
    font-size: 0.98rem;
    line-height: 1.55;
  }
  .lire-suite {
    display: inline-block;
    margin-top: 1rem;
    font-style: italic;
    color: var(--sang);
    font-size: 0.95rem;
  }
</style>
